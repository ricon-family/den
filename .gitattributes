
# Encrypted paths — transparently encrypted by git-crypt on push/pull.
# Never store sensitive content outside these patterns.
# Run 'mise run encrypt:setup' to initialize on a new machine.

# Agent rooms — everything inside each agent's room is private
agents/*/Zettels/**        filter=git-crypt diff=git-crypt
agents/*/AGENTS.md         filter=git-crypt diff=git-crypt
agents/*/mise.toml         filter=git-crypt diff=git-crypt
agents/*/.mise/tasks/**    filter=git-crypt diff=git-crypt

# Notes — everything under notes/ is encrypted
notes/**                   filter=git-crypt diff=git-crypt
