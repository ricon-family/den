
# Encrypted paths — transparently encrypted by git-crypt on push/pull.
# Never store sensitive content outside these patterns.
# Run 'notes encrypt:setup' to initialize on a new machine.

# Notes — everything under notes/ is encrypted (identity files, HUMAN.md, shared docs)
notes/**                   filter=git-crypt diff=git-crypt
submodules/.manifest                     filter=git-crypt diff=git-crypt
notes/.manifest merge=manifest
