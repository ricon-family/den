#!/usr/bin/env bash
#MISE description="Initialize git-crypt in the den repo — run once per machine to set up encrypted zettels"
#USAGE flag "--gpg-key <fingerprint>" help="Extra GPG key fingerprint to add as collaborator"
set -eo pipefail

DEN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

# --- Ensure git-crypt is installed ---
if ! command -v git-crypt &>/dev/null; then
  echo "git-crypt not found. Installing..."
  mise -C "$DEN_DIR" run encrypt:install
fi

# --- Already initialized? ---
if [ -d "$DEN_DIR/.git/git-crypt" ]; then
  echo "git-crypt already initialized in this repo."
  echo "To add a new collaborator: mise run encrypt:add-user --gpg-key <fingerprint>"
  echo "To check status:           mise run encrypt:status"
  exit 0
fi

# --- Initialize ---
echo "Initializing git-crypt..."
git -C "$DEN_DIR" crypt init

# --- Add GPG keys for all den residents ---
# Reads user.signingkey from ~/agents/<name>/.gitconfig (set by: shimmer gpg:setup <name>)
echo ""
echo "Adding agent GPG keys..."

skipped=()
for room in "$DEN_DIR/agents"/*/; do
  [ -d "$room" ] || continue
  name=$(basename "$room")
  gitconfig="$HOME/agents/$name/.gitconfig"

  if [ ! -f "$gitconfig" ]; then
    echo "  - $name — no .gitconfig at ~/agents/$name/.gitconfig, skipping"
    skipped+=("$name")
    continue
  fi

  key=$(git config --file "$gitconfig" user.signingkey 2>/dev/null || true)
  if [ -z "$key" ]; then
    echo "  - $name — no signingkey configured, skipping"
    skipped+=("$name")
    continue
  fi

  if gpg --list-keys "$key" &>/dev/null; then
    echo "  + $name ($key)"
    git -C "$DEN_DIR" crypt add-gpg-user --trusted "$key"
  else
    echo "  - $name ($key) — key not in local keyring, skipping"
    skipped+=("$name")
  fi
done

if [ "${#skipped[@]}" -gt 0 ]; then
  echo ""
  echo "  Note: ${#skipped[@]} agent(s) skipped. To add them later:"
  echo "    1. Have them run: shimmer gpg:setup <name>  (sets up GPG key + .gitconfig)"
  echo "    2. Then run:      mise run encrypt:add-user --gpg-key <fingerprint>"
fi

# --- Add extra key if provided ---
if [ -n "${usage_gpg_key:-}" ]; then
  echo "  + extra key: $usage_gpg_key"
  git -C "$DEN_DIR" crypt add-gpg-user --trusted "$usage_gpg_key"
fi

# --- Create .gitattributes ---
GITATTRIBUTES="$DEN_DIR/.gitattributes"
if ! grep -q "git-crypt" "$GITATTRIBUTES" 2>/dev/null; then
  cat >> "$GITATTRIBUTES" <<'EOF'

# Encrypted paths — transparently encrypted by git-crypt on push/pull.
# Never store sensitive content outside these patterns.
agents/*/Zettels/**  filter=git-crypt diff=git-crypt
agents/*/AGENTS.md   filter=git-crypt diff=git-crypt
notes/private/**     filter=git-crypt diff=git-crypt
EOF
  echo "Updated .gitattributes with encrypted path patterns."
fi

# --- Install pre-commit hook ---
HOOK="$DEN_DIR/.git/hooks/pre-commit"
cat > "$HOOK" <<'HOOK_EOF'
#!/usr/bin/env bash
# Prevent accidentally committing plaintext files that should be encrypted.
set -eo pipefail

if ! command -v git-crypt &>/dev/null; then
  echo "WARNING: git-crypt not found — skipping encryption check" >&2
  exit 0
fi

bad_files=()
encrypted_files=$(git-crypt status -e 2>/dev/null | awk '{print $2}' || true)
[ -z "$encrypted_files" ] && exit 0

while IFS= read -r file; do
  # Match full path exactly (not partial) to avoid false positives
  if echo "$encrypted_files" | grep -qxF "$file"; then
    if git-crypt status "$file" 2>&1 | grep -q "not encrypted"; then
      bad_files+=("$file")
    fi
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "${#bad_files[@]}" -gt 0 ]; then
  echo "ERROR: Staged files should be encrypted but are plaintext:" >&2
  printf '  %s\n' "${bad_files[@]}" >&2
  echo "" >&2
  echo "Run 'mise run encrypt:unlock' if git-crypt is locked, then re-stage." >&2
  exit 1
fi
HOOK_EOF
chmod +x "$HOOK"
echo "Installed pre-commit hook."

echo ""
echo "Done! Next steps:"
echo "  1. Add Or's GPG key:  mise run encrypt:add-user --gpg-key <fingerprint>"
echo "  2. Check status:      mise run encrypt:status"
echo "  3. Commit the setup:  git add .gitattributes .git-crypt && git commit"
echo "  4. Place zettels in   agents/<name>/Zettels/ — they encrypt on push"
