#!/usr/bin/env bash
#MISE description="Unlock encrypted zettels using your GPG key"
set -eo pipefail

DEN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

if ! command -v git-crypt &>/dev/null; then
  echo "Error: git-crypt is not installed. Run: mise run encrypt:setup" >&2
  exit 1
fi

if [ ! -d "$DEN_DIR/.git/git-crypt" ]; then
  echo "git-crypt not initialized in this repo. Run: mise run encrypt:setup" >&2
  exit 1
fi

echo "Unlocking den with your GPG key..."
git -C "$DEN_DIR" crypt unlock
echo "Unlocked. Encrypted zettels are now readable."
