#!/usr/bin/env bash
#MISE description="Install post-commit auto-fix + pre-push guard for ~/agents/*/okwai/ clones"
#USAGE flag "--dry-run" help="Show what would change without writing anything"
#USAGE long_about "Two-layer defence against leaking @ricon.family commits to Walmart-internal okwai.\n\nshimmer agents run with GIT_AUTHOR_EMAIL env vars set to <agent>@ricon.family. Env vars beat git config, so no amount of git-config trickery (includeIf, etc.) can change the author at commit time. The hooks below run after / before the boundaries where it actually matters.\n\n  1. <clone>/.git/hooks/post-commit\n     Auto-rewrites the commit author/committer when @ricon.family\n     slips through. Re-runs 'git commit --amend --reset-author' with\n     Or's identity injected as command-line env vars (command-line\n     env beats inherited env). Recursion-safe via\n     OKWAI_GUARD_AMENDING sentinel. Delegates to any project-side\n     .hooks/post-commit at the end.\n     \n     The amend re-signs via each agent's per-agent overlay\n     (~/agents/<agent>/.gitconfig sets commit.gpgsign=true and\n     user.signingkey). Result: author/committer = Or Ricon (visible\n     to SWISS and similar), GPG signature = agent's key (visible to\n     'git log --show-signature' as the only attribution channel).\n\n  2. <clone>/.git/hooks/pre-push\n     Final safety net. Refuses any push containing a @ricon.family-\n     authored commit, regardless of how it got past the post-commit\n     auto-fix (e.g. commits pre-dating the install, or commits made\n     with --no-verify across both pre-commit AND post-commit).\n\nIdempotent. Re-run after pulling den, after re-cloning okwai, or\nwhen adding a new agent home. The task also cleans up legacy\n~/.gitconfig.walmart-okwai + includeIf artifacts from an earlier\ntask iteration that has been simplified out."

set -euo pipefail

DRY_RUN="${usage_dry_run:-false}"

# Content compare: `$(cat ...)` strips trailing newlines, so append a
# sentinel byte to both sides to make the comparison exact.
file_matches() {
	local file="$1" expected="$2"
	[[ -f "$file" ]] || return 1
	[[ "$(cat "$file"; printf .)" == "${expected}." ]]
}

# ─────────────────────────────────────────────────────────────────────
# Hook source-of-truth blocks (heredocs read into variables).
# ─────────────────────────────────────────────────────────────────────

read -r -d '' POST_COMMIT_CONTENT <<'POST_COMMIT_EOF' || true
#!/usr/bin/env bash
# Post-commit auto-fix for Walmart okwai clones.
#
# When shimmer's GIT_AUTHOR_EMAIL env var (e.g. zeke@ricon.family)
# overrides git config at commit time, this hook detects the mismatch
# right after the commit object is created and rewrites it via
# `git commit --amend --reset-author` with the correct identity
# injected as command-line env vars (command-line env beats inherited
# env). The amend re-signs via the per-agent overlay (signingkey +
# commit.gpgsign=true), so author/committer = Or Ricon while the GPG
# signature still attributes to the actual agent.
#
# Installed by den's git:okwai:setup-identity-guards task — re-run to
# refresh.

# Recursion guard: the amend below re-fires post-commit; the sentinel
# makes the second invocation a no-op.
[[ "${OKWAI_GUARD_AMENDING:-}" == "1" ]] && exit 0

set -euo pipefail

author_email=$(git log -1 --format='%ae')
committer_email=$(git log -1 --format='%ce')

if [[ "$author_email" == *@ricon.family ]] || [[ "$committer_email" == *@ricon.family ]]; then
	# --reset-author is required: `git commit --amend` preserves the
	#   original author by default, so env vars alone would only fix
	#   the committer. --reset-author re-takes author from env+config.
	# --allow-empty preserves probe / no-change commits; not amending
	#   would error if the parent commit is empty.
	OKWAI_GUARD_AMENDING=1 \
		GIT_AUTHOR_NAME='Or Ricon' \
		GIT_AUTHOR_EMAIL='or.ricon@walmart.com' \
		GIT_COMMITTER_NAME='Or Ricon' \
		GIT_COMMITTER_EMAIL='or.ricon@walmart.com' \
		git commit --amend --no-edit --no-verify --allow-empty --reset-author --quiet

	echo "okwai identity guard: rewrote $author_email → or.ricon@walmart.com" >&2
fi

# Delegate to project post-commit if one exists (future-proofing).
project_hook="$(git rev-parse --show-toplevel)/.hooks/post-commit"
if [[ -x "$project_hook" ]]; then
	exec "$project_hook"
fi
POST_COMMIT_EOF

read -r -d '' PRE_PUSH_CONTENT <<'PRE_PUSH_EOF' || true
#!/usr/bin/env bash
# Pre-push guard for Walmart okwai clones.
# Final safety net: refuses any push containing a commit authored under
# @ricon.family, regardless of how it got past the post-commit auto-fix.
# Installed by den's git:okwai:setup-identity-guards task — re-run to refresh.

set -euo pipefail

ZERO="0000000000000000000000000000000000000000"
fail=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
	# Skip ref deletions (no new commits being pushed).
	[[ "$local_sha" == "$ZERO" ]] && continue

	if [[ "$remote_sha" == "$ZERO" ]]; then
		# New ref — commits unreachable from any tracked remote.
		range=("$local_sha" --not --remotes)
	else
		# Existing ref — only newly-pushed commits.
		range=("$remote_sha..$local_sha")
	fi

	offenders=$(git log "${range[@]}" --format='%h %ae' 2>/dev/null \
		| grep -E '@ricon\.family' | head -5 || true)
	if [[ -n "$offenders" ]]; then
		echo "" >&2
		echo "ERROR: Walmart pre-push guard — refusing to push commits with ricon.family author:" >&2
		echo "$offenders" | sed 's/^/  /' >&2
		echo "" >&2
		echo "  The post-commit auto-fix should have caught this. Possible causes:" >&2
		echo "    • commits pre-date the hook install (re-run setup-identity-guards)" >&2
		echo "    • hook bypassed via core.hooksPath override" >&2
		echo "" >&2
		echo "  Manual fix for affected commits:" >&2
		echo "    git rebase -i <base> --exec 'git commit --amend --reset-author --no-edit'" >&2
		echo "" >&2
		fail=1
	fi
done

exit $fail
PRE_PUSH_EOF

# ─────────────────────────────────────────────────────────────────────
# Step 1: install hooks in each ~/agents/*/okwai/ clone
# ─────────────────────────────────────────────────────────────────────

install_hook() {
	local hook_path="$1" content="$2" rel="$3" label="$4"
	if file_matches "$hook_path" "$content"; then
		echo "  ✓ $rel — $label up to date"
	elif [[ "$DRY_RUN" == "true" ]]; then
		echo "  [dry-run] would install: $rel/.git/hooks/$label"
	else
		printf '%s' "$content" >"$hook_path"
		chmod +x "$hook_path"
		echo "  ✓ $rel — installed $label"
	fi
}

echo "── Step 1: hooks in each okwai clone ──"
shopt -s nullglob
clones=("$HOME"/agents/*/okwai/.git)
if [[ ${#clones[@]} -eq 0 ]]; then
	echo "  (no ~/agents/*/okwai/ clones found)"
fi
for git_dir in "${clones[@]}"; do
	clone="${git_dir%/.git}"
	rel="${clone/#$HOME/~}"
	install_hook "$git_dir/hooks/post-commit" "$POST_COMMIT_CONTENT" "$rel" "post-commit"
	install_hook "$git_dir/hooks/pre-push" "$PRE_PUSH_CONTENT" "$rel" "pre-push"
done

# ─────────────────────────────────────────────────────────────────────
# Step 2: clean up legacy includeIf + override file from earlier
#         task iteration (harmless to keep, but tidier without).
# ─────────────────────────────────────────────────────────────────────

LEGACY_INCLUDE_FILE="$HOME/.gitconfig.walmart-okwai"
LEGACY_INCLUDE_PATTERN='gitdir:~/agents/*/okwai/'
LEGACY_CONFIG_KEY="includeIf.$LEGACY_INCLUDE_PATTERN.path"

legacy_value="$(git config --global --get "$LEGACY_CONFIG_KEY" 2>/dev/null || true)"

if [[ -f "$LEGACY_INCLUDE_FILE" ]] || [[ -n "$legacy_value" ]]; then
	echo ""
	echo "── Step 2: clean up legacy includeIf layer ──"

	if [[ -f "$LEGACY_INCLUDE_FILE" ]]; then
		if [[ "$DRY_RUN" == "true" ]]; then
			echo "  [dry-run] would remove: $LEGACY_INCLUDE_FILE"
		else
			rm -f "$LEGACY_INCLUDE_FILE"
			echo "  ✓ removed $LEGACY_INCLUDE_FILE"
		fi
	fi

	if [[ -n "$legacy_value" ]]; then
		if [[ "$DRY_RUN" == "true" ]]; then
			echo "  [dry-run] would unset: git config --global --unset-all '$LEGACY_CONFIG_KEY'"
		else
			# --unset-all removes every entry; --remove-section would
			# leave the empty [includeIf "..."] header behind.
			git config --global --unset-all "$LEGACY_CONFIG_KEY"
			echo "  ✓ unset includeIf from ~/.gitconfig"
		fi
	fi
fi

echo ""
echo "Done. Verify with a probe commit:"
echo "  cd ~/agents/<agent>/okwai && git commit --allow-empty --no-verify -m 'identity probe'"
echo "  git log -1 --format='%an <%ae>'            # → Or Ricon <or.ricon@walmart.com>"
echo "  git log -1 --show-signature 2>&1 | grep gpg # → signed by the agent's key"
