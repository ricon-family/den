#!/usr/bin/env bash
#MISE description="Set up identity overrides + post-commit auto-fix + pre-push guard for ~/agents/*/okwai/ clones"
#USAGE flag "--dry-run" help="Show what would change without writing anything"
#USAGE long_about "Three-layer defence against leaking @ricon.family commits to Walmart-internal okwai:\n\n  1. ~/.gitconfig.walmart-okwai loaded via includeIf 'gitdir:~/agents/*/okwai/'\n     sets user.name/email and commit.gpgsign=false. Applies in any\n     interactive shell that respects git config (e.g. Or working\n     directly, not as a shimmer agent).\n\n  2. <clone>/.git/hooks/post-commit auto-rewrites the commit author/committer\n     when @ricon.family slips past layer 1 (e.g. shimmer agents whose\n     GIT_AUTHOR_EMAIL env vars override config). Transparent fix:\n     the agent sees a one-line message and the commit lands correctly.\n\n  3. <clone>/.git/hooks/pre-push refuses to push any commit containing\n     a @ricon.family author, regardless of how it got past layers 1+2.\n\nIdempotent: safe to re-run after pulling den, after re-cloning okwai, or\nwhen adding a new agent home. Nothing depends on den being present after\nthe task completes."

set -euo pipefail

DRY_RUN="${usage_dry_run:-false}"

# ─────────────────────────────────────────────────────────────────────
# Step 1: identity override file (loaded via includeIf in step 2)
# ─────────────────────────────────────────────────────────────────────

INCLUDE_FILE="$HOME/.gitconfig.walmart-okwai"
# Note: signing is deliberately NOT disabled here. Author/committer get
# normalised to Or Ricon (visible to SWISS and other Walmart systems
# that email contributors), but the GPG signature continues to use
# whichever agent's key is set in the per-agent overlay
# (~/agents/<agent>/.gitconfig). That signature is the ONLY
# attribution channel left once identity is normalised — it lets
# `git log --show-signature` answer 'which agent actually made this
# commit?'. The signature is git-internal metadata; Walmart's
# SWISS-style scanners don't email based on it.
INCLUDE_CONTENT='# Identity override for ~/agents/*/okwai/ clones.
# Loaded by ~/.gitconfig via includeIf. Managed by den task
# git:okwai:setup-identity-guards — re-run to refresh.
#
# Signing is left to the per-agent overlay so the GPG signature
# carries agent attribution (the only channel left after author/
# committer are normalised to Or Ricon).
[user]
    name = Or Ricon
    email = or.ricon@walmart.com
'

# Content compare: `$(cat ...)` strips trailing newlines, so append a
# sentinel byte to both sides to make the comparison exact.
file_matches() {
	local file="$1" expected="$2"
	[[ -f "$file" ]] || return 1
	[[ "$(cat "$file"; printf .)" == "${expected}." ]]
}

echo "── Step 1: identity override file ──"
if file_matches "$INCLUDE_FILE" "$INCLUDE_CONTENT"; then
	echo "  ✓ $INCLUDE_FILE — already up to date"
elif [[ "$DRY_RUN" == "true" ]]; then
	echo "  [dry-run] would write: $INCLUDE_FILE"
else
	printf '%s' "$INCLUDE_CONTENT" >"$INCLUDE_FILE"
	echo "  ✓ wrote $INCLUDE_FILE"
fi

# ─────────────────────────────────────────────────────────────────────
# Step 2: ensure includeIf block exists in ~/.gitconfig
# ─────────────────────────────────────────────────────────────────────
#
# Match every clone under ~/agents/*/okwai/ — covers current agents
# (zeke, baby-joel, ikma) plus any future ones added on this machine.
# `gitdir:~/...` expands ~ to $HOME at evaluation time.

INCLUDE_PATTERN='gitdir:~/agents/*/okwai/'
CONFIG_KEY="includeIf.$INCLUDE_PATTERN.path"
# Intentionally literal `~` — git resolves it to $HOME at read time,
# which keeps the include file portable if the home directory ever
# changes. Don't substitute $HOME here.
# shellcheck disable=SC2088
EXPECTED_VALUE='~/.gitconfig.walmart-okwai'

echo ""
echo "── Step 2: ~/.gitconfig includeIf ──"
current_value="$(git config --global --get "$CONFIG_KEY" 2>/dev/null || true)"
if [[ "$current_value" == "$EXPECTED_VALUE" ]]; then
	echo "  ✓ includeIf for okwai clones already present"
elif [[ "$DRY_RUN" == "true" ]]; then
	echo "  [dry-run] would set: git config --global $CONFIG_KEY $EXPECTED_VALUE"
else
	git config --global "$CONFIG_KEY" "$EXPECTED_VALUE"
	echo "  ✓ added includeIf for okwai clones"
fi

# ─────────────────────────────────────────────────────────────────────
# Step 3: pre-push hook in each ~/agents/*/okwai/ clone
# ─────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────
# Hook source-of-truth blocks (heredocs read into variables).
# ─────────────────────────────────────────────────────────────────────

read -r -d '' POST_COMMIT_CONTENT <<'POST_COMMIT_EOF' || true
#!/usr/bin/env bash
# Post-commit auto-fix for Walmart okwai clones.
#
# When shimmer's GIT_AUTHOR_EMAIL env var (e.g. zeke@ricon.family)
# overrides git config at commit time, this hook detects the mismatch
# right after the commit object is created and rewrites it via
# `git commit --amend` with the correct identity injected as env vars
# (env on the command line beats inherited env).
#
# Installed by den's git:okwai:setup-identity-guards task — re-run to
# refresh.

# Recursion guard: the amend below re-fires post-commit; the sentinel
# makes the second invocation a no-op.
[[ "${OKWAI_GUARD_AMENDING:-}" == "1" ]] && exit 0

set -euo pipefail

author_email=$(git log -1 --format='%ae')
committer_email=$(git log -1 --format='%ce')

if [[ "$author_email" == *@ricon.family ]] || [[ "$committer_email" == *@ricon.family ]]; then
	# --reset-author is required: `git commit --amend` preserves the
	#   original author by default, so env vars alone would only fix
	#   the committer. --reset-author re-takes author from env+config.
	# --allow-empty preserves probe / no-change commits; not amending
	#   would error if the parent commit is empty.
	OKWAI_GUARD_AMENDING=1 \
		GIT_AUTHOR_NAME='Or Ricon' \
		GIT_AUTHOR_EMAIL='or.ricon@walmart.com' \
		GIT_COMMITTER_NAME='Or Ricon' \
		GIT_COMMITTER_EMAIL='or.ricon@walmart.com' \
		git commit --amend --no-edit --no-verify --allow-empty --reset-author --quiet

	echo "okwai identity guard: rewrote $author_email → or.ricon@walmart.com" >&2
fi

# Delegate to project post-commit if one exists (future-proofing).
project_hook="$(git rev-parse --show-toplevel)/.hooks/post-commit"
if [[ -x "$project_hook" ]]; then
	exec "$project_hook"
fi
POST_COMMIT_EOF

read -r -d '' PRE_PUSH_CONTENT <<'PRE_PUSH_EOF' || true
#!/usr/bin/env bash
# Pre-push guard for Walmart okwai clones.
# Final safety net: refuses any push containing a commit authored under
# @ricon.family, regardless of how it got past the post-commit auto-fix.
# Installed by den's git:okwai:setup-identity-guards task — re-run to refresh.

set -euo pipefail

ZERO="0000000000000000000000000000000000000000"
fail=0

while read -r _local_ref local_sha _remote_ref remote_sha; do
	# Skip ref deletions (no new commits being pushed).
	[[ "$local_sha" == "$ZERO" ]] && continue

	if [[ "$remote_sha" == "$ZERO" ]]; then
		# New ref — commits unreachable from any tracked remote.
		range=("$local_sha" --not --remotes)
	else
		# Existing ref — only newly-pushed commits.
		range=("$remote_sha..$local_sha")
	fi

	offenders=$(git log "${range[@]}" --format='%h %ae' 2>/dev/null \
		| grep -E '@ricon\.family' | head -5 || true)
	if [[ -n "$offenders" ]]; then
		echo "" >&2
		echo "ERROR: Walmart pre-push guard — refusing to push commits with ricon.family author:" >&2
		echo "$offenders" | sed 's/^/  /' >&2
		echo "" >&2
		echo "  The post-commit auto-fix should have caught this. Possible causes:" >&2
		echo "    • commits pre-date the hook install (re-run setup-identity-guards)" >&2
		echo "    • hook bypassed via core.hooksPath override" >&2
		echo "" >&2
		echo "  Manual fix for affected commits:" >&2
		echo "    git rebase -i <base> --exec 'git commit --amend --reset-author --no-edit'" >&2
		echo "" >&2
		fail=1
	fi
done

exit $fail
PRE_PUSH_EOF

# ─────────────────────────────────────────────────────────────────────
# Step 3: install hooks in each ~/agents/*/okwai/ clone
# ─────────────────────────────────────────────────────────────────────

install_hook() {
	local hook_path="$1" content="$2" rel="$3" label="$4"
	if file_matches "$hook_path" "$content"; then
		echo "  ✓ $rel — $label up to date"
	elif [[ "$DRY_RUN" == "true" ]]; then
		echo "  [dry-run] would install: $rel/.git/hooks/$label"
	else
		printf '%s' "$content" >"$hook_path"
		chmod +x "$hook_path"
		echo "  ✓ $rel — installed $label"
	fi
}

echo ""
echo "── Step 3: hooks in each okwai clone ──"
shopt -s nullglob
clones=("$HOME"/agents/*/okwai/.git)
if [[ ${#clones[@]} -eq 0 ]]; then
	echo "  (no ~/agents/*/okwai/ clones found)"
fi
for git_dir in "${clones[@]}"; do
	clone="${git_dir%/.git}"
	rel="${clone/#$HOME/~}"
	install_hook "$git_dir/hooks/post-commit" "$POST_COMMIT_CONTENT" "$rel" "post-commit"
	install_hook "$git_dir/hooks/pre-push" "$PRE_PUSH_CONTENT" "$rel" "pre-push"
done

echo ""
echo "Done. Verify with a probe commit (auto-fix should rewrite the bad author):"
echo "  cd ~/agents/<agent>/okwai && git commit --allow-empty -m 'identity probe'"
echo "  git log -1 --format='%an <%ae>'   # should print: Or Ricon <or.ricon@walmart.com>"
