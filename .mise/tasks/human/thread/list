#!/usr/bin/env bash
#MISE description="List HUMAN.md threads with status and who's waiting"
set -eo pipefail

DEN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../../.." && pwd)"
HUMAN_FILE="$DEN_DIR/HUMAN.md"

if [ ! -f "$HUMAN_FILE" ]; then
  echo "No HUMAN.md found at $HUMAN_FILE" >&2
  exit 1
fi

# Parse threads: callout type, title, participants, last author, waiting-on
# Output: tab-separated rows for gum table
output=$(HUMAN_FILE="$HUMAN_FILE" python3 << 'PYEOF'
import re, os

content = open(os.environ["HUMAN_FILE"]).read()

# Only parse content after the header marker
marker = "--- HEADER END ---"
idx = content.find(marker)
if idx >= 0:
    content = content[idx + len(marker):]

# Match callout openers
callout_pat = re.compile(r"^> \[!(note|warning|success)\][+-]?\s*(.*)", re.MULTILINE)

threads = []
for m in callout_pat.finditer(content):
    kind = m.group(1)
    title = m.group(2).strip()
    # Strip 👈 from title
    title = re.sub(r"^👈\s*", "", title).strip()

    # Collect body: lines starting with "> " until a non-callout line
    body_lines = []
    for line in content[m.end():].split("\n"):
        stripped = line.rstrip()
        if stripped.startswith("> "):
            body_lines.append(stripped[2:])
        elif stripped == ">":
            body_lines.append("")
        elif stripped == "":
            continue
        else:
            break

    # Extract [Name] or **[Name]** markers in order of appearance
    name_pat = re.compile(r"^(?:\*\*)?\[([A-Za-z][A-Za-z -]*?)\](?:\*\*)?")
    authors = []
    for l in body_lines:
        nm = name_pat.match(l)
        if nm:
            authors.append(nm.group(1))

    participants = sorted(set(authors)) if authors else []
    last_author = authors[-1] if authors else "—"

    # Determine who the thread is waiting on
    if kind == "success":
        waiting = "resolved"
    elif not authors:
        waiting = "—"
    elif last_author == "Or":
        waiting = "agent"
    else:
        waiting = "Or"

    # Status indicator
    if kind == "warning":
        status = "👈"
    elif kind == "success":
        status = "✓"
    else:
        status = " "

    threads.append({
        "status": status,
        "title": title,
        "participants": ", ".join(participants) if participants else "—",
        "last_author": last_author,
        "waiting": waiting,
    })

if not threads:
    print("NO_THREADS")
else:
    # Tab-separated for gum table
    print("\t".join([" ", "Thread", "Participants", "Last", "Waiting on"]))
    for t in threads:
        print("\t".join([
            t["status"],
            t["title"],
            t["participants"],
            t["last_author"],
            t["waiting"],
        ]))
PYEOF
)

if [ "$output" = "NO_THREADS" ]; then
  gum style --faint "No threads found in HUMAN.md"
else
  echo "$output" | gum table --print --separator "	" --border rounded \
    --border.foreground 240 --header.foreground 81
fi
