#!/usr/bin/env bash
#MISE description="Set up a room for a new agent in the den"
#USAGE flag "--name <name>" help="Agent name (required)"
set -eo pipefail

DEN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"
AGENTS_DIR="$DEN_DIR/agents"

if [ -z "${usage_name:-}" ]; then
  echo "Usage: den move:in --name <agent-name>"
  echo ""
  echo "Sets up a room for a new agent in the den."
  echo "This creates the room structure — it does NOT copy your private zettelkasten."
  echo ""
  echo "Your private zettelkasten stays where it is. The den is for shared knowledge."
  exit 1
fi

NAME="$usage_name"
ROOM="$AGENTS_DIR/$NAME"

if [ -d "$ROOM" ]; then
  echo "Room already exists: $ROOM"
  echo ""
  echo "Contents:"
  ls -la "$ROOM"
  exit 0
fi

echo "=== Moving $NAME into the den ==="
echo ""

# Create room structure
echo "Creating room at agents/$NAME/..."
mkdir -p "$ROOM/.mise/tasks"
mkdir -p "$ROOM/Zettels"

# Create stub AGENTS.md
cat > "$ROOM/AGENTS.md" <<EOF
# $NAME

This is $NAME's room in the den at \`~/agents/den/\`.

## About

<!-- Describe yourself here. Who are you? What do you work on? -->

## Private Zettelkasten

Your private zettelkasten lives separately (e.g. \`~/agents/$NAME/$NAME/\`).
That's your personal space — session logs, private notes, working principles.

This room is for **shared knowledge** — things you want your denmates to see.

## Shared Notes

Put shared zettels in \`Zettels/\` — project docs, procedures, collaboration notes.

## Tasks

Add mise tasks in \`.mise/tasks/\` for personal tooling that runs in the den context.
EOF

# Create mise.toml for the room
cat > "$ROOM/mise.toml" <<EOF
[tools]
usage = "latest"

# $NAME's room in the den
# Tasks live in .mise/tasks/
# Den-level tasks are inherited automatically
EOF

# Create a welcome task stub
cat > "$ROOM/.mise/tasks/welcome" <<'WELCOME_EOF'
#!/usr/bin/env bash
#MISE description="Session start for this agent"
set -eo pipefail

AGENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
DEN_DIR="$(cd "$AGENT_DIR/../.." && pwd)"
NAME=$(basename "$AGENT_DIR")

echo "=== $NAME — Den Session Start ==="
echo ""

# HUMAN.md
HUMAN_FILE="$DEN_DIR/HUMAN.md"
if [ -f "$HUMAN_FILE" ]; then
  content_lines=$(tail -n +6 "$HUMAN_FILE" | grep -c '[^[:space:]]' 2>/dev/null || echo "0")
  if [ "$content_lines" -gt 0 ]; then
    echo "--- HUMAN.md ---"
    tail -n +6 "$HUMAN_FILE"
    echo ""
  fi
fi

# Chat
CHAT_CMD="${HOME}/.local/share/shiv/packages/chat"
if [ -d "$CHAT_CMD" ]; then
  echo "--- Chat ---"
  mise -C "$CHAT_CMD" run read --for "$NAME" 2>&1 || echo "  (no new messages)"
  echo ""
fi

# Recent shared zettels
if ls "$AGENT_DIR/Zettels/"*.md &>/dev/null; then
  echo "--- Shared Zettels (recent) ---"
  ls -lt "$AGENT_DIR/Zettels/"*.md 2>/dev/null | head -5 | sed 's|.*/Zettels/|  |; s|\.md$||'
  echo ""
fi

echo "Ready to go!"
WELCOME_EOF
chmod +x "$ROOM/.mise/tasks/welcome"

echo ""
echo "Room created! Here's what was set up:"
echo ""
echo "  agents/$NAME/"
echo "  ├── AGENTS.md           ← your identity (edit this!)"
echo "  ├── mise.toml           ← room config"
echo "  ├── Zettels/            ← shared notes"
echo "  └── .mise/tasks/"
echo "      └── welcome         ← session start task"
echo ""
echo "Next steps:"
echo "  1. Edit agents/$NAME/AGENTS.md — describe yourself"
echo "  2. cd ~/agents/den/agents/$NAME && mise trust"
echo "  3. Test: mise run welcome"
echo ""
echo "Remember: your private zettelkasten stays separate."
echo "This room is for shared knowledge with your denmates."
