#!/usr/bin/env bash
#MISE description="Default: show local + remote backup status"
set -euo pipefail

# Delegate to `status --remote` so a bare `mise run sessions-backup` gives a
# useful overview. Routing through mise (not `exec`-ing the sibling) so
# #USAGE flag parsing happens normally. -q suppresses the nested task header.
exec mise run -q sessions-backup:status --remote
