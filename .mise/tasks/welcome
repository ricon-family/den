#!/usr/bin/env bash
#MISE description="Den overview — who lives here, recent activity, HUMAN.md"
set -eo pipefail

DEN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
AGENTS_DIR="$DEN_DIR/agents"

# Colors
HEADING=212   # pink
SUBHEAD=81    # blue
DIM=240       # gray

# Section heading helper
section() {
  echo ""
  gum style --bold --foreground "$HEADING" "$1"
}

# ━━━ Header ━━━
echo ""
gum style --bold --foreground "$HEADING" --border double --border-foreground "$DIM" \
  --padding "0 2" "🏠 The Den"
gum style --faint "$(date '+%A, %B %-d, %Y · %-I:%M %p')"

# ━━━ Residents ━━━
section "Residents"
resident_rows=""
for room in "$AGENTS_DIR"/*/; do
  [ ! -d "$room" ] && continue
  name=$(basename "$room")
  last_activity=$(cd "$DEN_DIR" && git log -1 --format='%ar' -- "agents/$name/" 2>/dev/null || echo "unknown")
  resident_rows+="${name},${last_activity}"$'\n'
done
if [ -n "$resident_rows" ]; then
  printf "Agent,Last Active\n%s" "$resident_rows" \
    | gum table --print --separator "," --border rounded \
        --border.foreground "$DIM" --header.foreground "$SUBHEAD"
fi

# ━━━ HUMAN.md ━━━
HUMAN_FILE="$DEN_DIR/HUMAN.md"
if [ -f "$HUMAN_FILE" ]; then
  thread_summary=$(mise run human:thread:status 2>/dev/null || echo "")
  section "📝 HUMAN.md  ($thread_summary)"
  mise run human:thread:list 2>/dev/null || true
fi

# ━━━ Chat ━━━
section "💬 Chat"
CHAT_DATA_DIR="${HOME}/.local/share/chat"
if [ -d "$CHAT_DATA_DIR" ]; then
  chat_rows=""
  for chat_file in "$CHAT_DATA_DIR"/*.md; do
    [ ! -f "$chat_file" ] && continue
    channel=$(basename "$chat_file" .md)
    last_msg=$({ grep '^### ' "$chat_file" || true; } | tail -1)
    if [ -n "$last_msg" ]; then
      msg_info=$(echo "$last_msg" | sed 's/^### //')
      msg_count=$(grep -c '^### ' "$chat_file" || true)
      chat_rows+="${channel},${msg_count},${msg_info}"$'\n'
    fi
  done
  if [ -n "$chat_rows" ]; then
    printf "Channel,Msgs,Last Activity\n%s" "$chat_rows" \
      | gum table --print --separator "," --border rounded \
          --border.foreground "$DIM" --header.foreground "$SUBHEAD"
  else
    gum style --faint "(no messages in any channel)"
  fi

  # Quick reference — detect agent name from env (set by shimmer)
  _agent="${AGENT_NAME:-${GIT_AUTHOR_NAME:-}}"
  if [ -n "$_agent" ]; then
    _agent_lower=$(echo "$_agent" | tr '[:upper:]' '[:lower:]')
    echo ""
    (
      printf 'Action\tCommand\n'
      printf 'Read new messages\tchat read --for %s\n' "$_agent_lower"
      printf 'Send a message\tchat send --from %s <msg>\n' "$_agent_lower"
      printf 'Wait until @mentioned\tchat wait --for %s\n' "$_agent_lower"
      printf 'Peek without marking read\tchat check --for %s\n' "$_agent_lower"
      printf 'List all channels\tchat list\n'
    ) | gum table --print --separator "	" --border rounded \
          --border.foreground "$DIM" --header.foreground "$DIM"
  fi
else
  gum style --faint "(chat not installed — run: shiv install chat)"
fi

# ━━━ Repo & Status ━━━
section "📦 Repo"
cd "$DEN_DIR"
branch=$(git branch --show-current 2>/dev/null)
dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')

if [ "$dirty" -gt 0 ]; then
  branch_status="$branch ($dirty uncommitted)"
else
  branch_status="$branch (clean)"
fi

tracking=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || echo "")
sync_status=""
if [ -n "$tracking" ]; then
  ahead=$(git rev-list "$tracking..HEAD" --count 2>/dev/null || echo "0")
  behind=$(git rev-list "HEAD..$tracking" --count 2>/dev/null || echo "0")
  [ "$ahead" -gt 0 ] && sync_status+="↑${ahead} ahead "
  [ "$behind" -gt 0 ] && sync_status+="↓${behind} behind "
  [ -z "$sync_status" ] && sync_status="up to date"
fi

repo_rows="Branch,${branch_status}"$'\n'
[ -n "$sync_status" ] && repo_rows+="Remote,${sync_status}"$'\n'

# Open issues
issue_count=$(GH_HOST=github.com gh issue list --repo ricon-family/den --state open --json number --jq 'length' 2>/dev/null || echo "?")
repo_rows+="Issues,${issue_count} open"$'\n'

# Encryption
if [ ! -d "$DEN_DIR/.git/git-crypt" ]; then
  enc_status="⚠ not set up → mise run encrypt:setup"
elif ! command -v git-crypt &>/dev/null; then
  enc_status="⚠ git-crypt not installed → mise run encrypt:setup"
elif git -C "$DEN_DIR" crypt status -e &>/dev/null; then
  enc_status="✓ unlocked"
else
  enc_status="⚠ locked → mise run encrypt:unlock"
fi
repo_rows+="Encryption,${enc_status}"

printf "Property,Status\n%s\n" "$repo_rows" \
  | gum table --print --separator "," --border rounded \
      --border.foreground "$DIM" --header.foreground "$SUBHEAD"

echo ""
