#!/usr/bin/env bash
#MISE description="Den overview — who lives here, recent activity, HUMAN.md"
set -eo pipefail

DEN_DIR="$MISE_CONFIG_ROOT"

# Colors
HEADING=212   # pink
SUBHEAD=81    # blue
DIM=240       # gray

# Section heading helper
section() {
  echo ""
  gum style --bold --foreground "$HEADING" "$1"
}

# ━━━ Header + Home Status ━━━
echo ""
gum style --bold --foreground "$HEADING" --border double --border-foreground "$DIM" \
  --padding "0 2" "🏠 The Den"
gum style --faint "$(date '+%A, %B %-d, %Y · %-I:%M %p')"

# Home repo status — shown early so it's clear this is about den
cd "$DEN_DIR"
branch=$(git branch --show-current 2>/dev/null)
dirty=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
if [ "$dirty" -gt 0 ]; then
  branch_status="$branch ($dirty uncommitted)"
else
  branch_status="$branch (clean)"
fi

tracking=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null || echo "")
sync_status=""
if [ -n "$tracking" ]; then
  ahead=$(git rev-list "$tracking..HEAD" --count 2>/dev/null || echo "0")
  behind=$(git rev-list "HEAD..$tracking" --count 2>/dev/null || echo "0")
  [ "$ahead" -gt 0 ] && sync_status+="↑${ahead} ahead "
  [ "$behind" -gt 0 ] && sync_status+="↓${behind} behind "
  [ -z "$sync_status" ] && sync_status="up to date"
fi

if [ ! -d "$DEN_DIR/.git/git-crypt" ]; then
  enc_status="⚠ not set up"
elif ! command -v git-crypt &>/dev/null; then
  enc_status="⚠ git-crypt missing"
elif [ -f "$DEN_DIR/.git/git-crypt/keys/default" ]; then
  enc_status="✓ unlocked"
else
  enc_status="⚠ locked"
fi

# Obfuscation status — check if notes are obfuscated or deobfuscated
obf_status="n/a"
if [ -f "$DEN_DIR/notes/.manifest" ]; then
  first_name=$(head -1 "$DEN_DIR/notes/.manifest" | cut -f2)
  if [ -n "$first_name" ] && [ -f "$DEN_DIR/notes/$first_name" ]; then
    obf_status="✓ deobfuscated"
  else
    obf_status="obfuscated"
  fi
fi

issue_count=$(gh issue list --state open --json number --jq 'length' 2>/dev/null || echo "?")

echo ""
printf "Branch,Remote,Issues,Encryption,Notes\n%s,%s,%s,%s,%s\n" \
  "$branch_status" "$sync_status" "${issue_count} open" "$enc_status" "$obf_status" \
  | gum table --print --separator "," --border rounded \
      --border.foreground "$DIM" --header.foreground "$SUBHEAD"

# ━━━ Residents ━━━
section "Residents"
agents=$(cd "$DEN_DIR" && mise run -q agent:list 2>/dev/null || true)
if [ -n "$agents" ]; then
  resident_rows=""
  while IFS= read -r name; do
    [ -z "$name" ] && continue
    last_activity=$(cd "$DEN_DIR" && git log -1 --format='%ar' --author="$name" 2>/dev/null || echo "")
    resident_rows+="${name},${last_activity}"$'\n'
  done <<< "$agents"
  printf "Agent,Last Active\n%s" "$resident_rows" \
    | gum table --print --separator "," --border rounded \
        --border.foreground "$DIM" --header.foreground "$SUBHEAD"
fi

# ━━━ HUMAN.md ━━━
HUMAN_FILE=$(cd "$DEN_DIR" && mise run -q human 2>/dev/null || true)
if [ -n "$HUMAN_FILE" ] && [ -f "$HUMAN_FILE" ]; then
  thread_summary=$(threads status --file "$HUMAN_FILE" 2>/dev/null || echo "")
  section "📝 HUMAN.md  ($thread_summary)"
  threads list --file "$HUMAN_FILE" 2>/dev/null || true
else
  section "📝 HUMAN.md"
  gum style --faint "(HUMAN_MD not set — see: mise run human)"
fi

# ━━━ Chat ━━━
section "💬 Chat"
if command -v chat &>/dev/null; then
  chat list 2>/dev/null || gum style --faint "(no chat channels)"

  # Quick reference — detect agent name from env (set by shimmer)
  _agent="${AGENT_NAME:-${GIT_AUTHOR_NAME:-}}"
  if [ -n "$_agent" ]; then
    _agent_lower=$(echo "$_agent" | tr '[:upper:]' '[:lower:]')
    echo ""
    (
      printf 'Action\tCommand\n'
      printf 'Read new messages (all)\tchat read\n'
      printf 'Read a specific channel\tchat read <channel>\n'
      printf 'Read only @%s mentions\tchat read --as %s\n' "$_agent_lower" "$_agent_lower"
      printf 'Send a message\tchat send --as %s <msg>\n' "$_agent_lower"
      printf 'Send to specific channel\tchat send --as %s --chat <channel> <msg>\n' "$_agent_lower"
      printf 'Wait until @mentioned\tchat wait --as %s\n' "$_agent_lower"
      printf 'Peek without marking read\tchat read --peek\n'
      printf 'List all channels\tchat list\n'
    ) | gum table --print --separator "	" --border rounded \
          --border.foreground "$DIM" --header.foreground "$DIM"
  fi
else
  gum style --faint "(chat not installed — run: shiv install chat)"
fi

# ━━━ Modules ━━━
# Hygiene checks for nested module clones:
#   - Pin freshness: warn when clone is behind origin/<default-branch>; user
#     decides whether to `modules update <name>` to bump.
#   - Notes hooks: ensure pre-commit hook is installed in notes-tracked
#     clones, since `modules init` does not install them and missing hooks
#     risk leaking plaintext on commit.
if [ -d "$DEN_DIR/modules" ]; then
  section "📦 Modules"
  module_rows=""
  for mod_path in "$DEN_DIR/modules"/*/; do
    [ -d "$mod_path/.git" ] || continue
    name=$(basename "$mod_path")

    # Pin freshness
    git -C "$mod_path" fetch -q 2>/dev/null || true
    default_branch=$(git -C "$mod_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
    default_branch=${default_branch:-main}
    behind=$(git -C "$mod_path" rev-list --count "HEAD..origin/${default_branch}" 2>/dev/null || echo 0)
    if [ "${behind:-0}" -gt 0 ]; then
      pin_status="⚠ ${behind} behind origin/${default_branch} → modules update ${name}"
    else
      pin_status="✓ at tip of ${default_branch}"
    fi

    # Notes hooks
    if [ ! -f "$mod_path/notes/.manifest" ]; then
      hook_status="n/a"
    elif [ -f "$mod_path/.git/hooks/pre-commit" ]; then
      hook_status="✓ installed"
    else
      (cd "$mod_path" && notes install-hooks >/dev/null 2>&1) || true
      hook_status="⚠ installed (was missing)"
    fi

    module_rows+="${name},${pin_status},${hook_status}"$'\n'
  done
  if [ -n "$module_rows" ]; then
    printf "Module,Pin,Hooks\n%s" "$module_rows" \
      | gum table --print --separator "," --border rounded \
          --border.foreground "$DIM" --header.foreground "$SUBHEAD"
  else
    gum style --faint "(no nested modules initialized — run: modules init)"
  fi
fi

# ━━━ Notes ━━━
# Disabled: notes list is too slow (~18s due to per-file farts calls). See den#10.
# section "📓 Notes"
# (cd "$DEN_DIR" && notes list -- --recent 5 2>/dev/null || true)

echo ""
